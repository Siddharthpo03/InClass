# =============================================================================
# InClass Backend - Environment Variables Template (P3 - No real values)
# =============================================================================
# Copy to .env and set values locally. NEVER commit .env to git.
#   cp .env.example .env
# =============================================================================

# Server
PORT=4000
NODE_ENV=development

# -----------------------------------------------------------------------------
# Required secrets (set in .env only; never commit real values)
# -----------------------------------------------------------------------------
JWT_SECRET=
BIOMETRIC_ENCRYPTION_KEY=
ADMIN_SECRET=
FRONTEND_URL=

# -----------------------------------------------------------------------------
# Database (Required)
# -----------------------------------------------------------------------------
DATABASE_URL=

# -----------------------------------------------------------------------------
# Optional - Email, CORS, API keys
# -----------------------------------------------------------------------------
# GMAIL_USER=youremail@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# ALLOWED_EMAIL_DOMAINS=@mgit.ac.in,@college.edu
# GOOGLE_MAPS_API_KEY=
# FACE_SIMILARITY_THRESHOLD=
# ADMIN_GATE_PASSPHRASE=
# AI_FACE_SERVICE_URL=http://127.0.0.1:8000
# AI_FACE_AUTO_START=true
# AI_FACE_PYTHON_CMD=python

# -----------------------------------------------------------------------------
# WebAuthn (biometric / passkey). Required for /api/biometrics/webauthn routes.
# -----------------------------------------------------------------------------
WEBAUTHN_RP_ID=localhost
# WEBAUTHN_RP_NAME=InClass Attendance System
# WEBAUTHN_ORIGIN=

# -----------------------------------------------------------------------------
# Socket.io CORS (required). Comma-separated list; must match frontend origins.
# -----------------------------------------------------------------------------
SOCKET_ORIGINS=http://localhost:5173,http://localhost:3000
