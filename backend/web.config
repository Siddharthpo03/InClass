<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <!-- IIS URL Rewrite to forward to Node.js -->
    <rewrite>
      <rules>
        <rule name="ReverseProxyInboundRule1" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://localhost:4000{REQUEST_URI}" />
        </rule>
      </rules>
    </rewrite>

    <!-- WebSocket support -->
    <webSocket enabled="true" />

    <!-- Node.js application handler -->
    <handlers>
      <add name="iisnode" path="server.js" verb="*" modules="iisnode" />
    </handlers>

    <!-- Increase timeout for deployments and long-running requests -->
    <system.webServer>
      <security>
        <requestFiltering>
          <requestLimits maxUrl="4096" maxQueryString="2048" maxAllowedContentLength="104857600" />
        </requestFiltering>
      </security>
    </system.webServer>

    <!-- iisnode configuration -->
    <iisnode watchedFiles="web.config,*.js" nodeProcessCountPerApplication="1" enableXFF="true" />

    <!-- Logging for debugging -->
    <logging>
      <centralLogFileDirectory="d:\home\LogFiles\nodejs" />
    </logging>
  </system.webServer>

  <appSettings>
    <!-- Node.js environment variables -->
    <add key="NODE_ENV" value="production" />
    <add key="PORT" value="4000" />
  </appSettings>

  <!-- URL rewrite to remove trailing slashes (optional) -->
  <system.webServer>
    <rewrite>
      <outboundRules>
        <rule name="Remove ETag Header" patternSyntax="Wildcard">
          <match serverVariable="RESPONSE_ETag" pattern=".*" />
          <action type="Rewrite" value="" />
        </rule>
      </outboundRules>
    </rewrite>
  </system.webServer>
</configuration>
