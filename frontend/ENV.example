# Frontend build-time configuration for Vite
# Copy this file to `.env` and set the value appropriately before building.
# Example for production: your deployed API base URL (HTTPS recommended).
# Vite exposes variables with the VITE_ prefix to the client code.

# Optional overrides used by the shared frontend URL helper.
VITE_API_BASE_URL=https://api.inclass.siddharthp.com/api
VITE_SOCKET_URL=https://api.inclass.siddharthp.com
VITE_ADMIN_BASE_URL=https://api.inclass.siddharthp.com
VITE_BACKEND_ORIGIN=https://api.inclass.siddharthp.com
