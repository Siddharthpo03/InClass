# =============================================================================
# InClass Frontend - Environment Variables Template (P3 - No real values)
# =============================================================================
# Copy to .env and set values locally. NEVER commit .env to git.
#   cp .env.example .env
# Vite exposes only variables prefixed with VITE_
# =============================================================================

# API base URL (e.g. http://localhost:4000/api in dev, /api in production)
VITE_API_BASE_URL=

# Socket.io URL (e.g. http://localhost:4000)
VITE_SOCKET_URL=
